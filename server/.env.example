# CareerSync AI — Server Environment Variables
# Copy this file to .env and fill in real values. Never commit .env.

# Server
PORT=5000

# CORS — set to your Vercel frontend URL in production
CORS_ORIGIN=http://localhost:5173

# MongoDB Atlas or Azure Cosmos DB (MongoDB API)
MONGODB_URI=

# Firebase Admin SDK — download service account JSON from Firebase Console
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ─── AI Provider ──────────────────────────────────────────────────────────────
# Controls which AI backend is used. Currently only "groq" is active.
# Set to "azure" in the future once Azure policy allows access.
AI_PROVIDER=groq

# ─── Groq (active) ────────────────────────────────────────────────────────────
# Get your key from: https://console.groq.com/keys
GROQ_API_KEY=
# Model to use — recommended: llama-3.3-70b-versatile
# Other options: llama-3.1-8b-instant (faster/cheaper), mixtral-8x7b-32768
GROQ_MODEL=llama-3.3-70b-versatile

# ─── Azure AI / Azure OpenAI (future — blocked by policy, leave blank for now) ─
AZURE_AI_ENDPOINT=
AZURE_AI_KEY=
AZURE_AI_DEPLOYMENT_NAME=
AZURE_AI_API_VERSION=2024-08-01-preview

# ─── Azure legacy vars (kept for backward compatibility) ──────────────────────
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=

# ─── Azure Blob Storage (optional — for resume/certificate uploads) ───────────
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER_NAME=

# ─── Azure Document Intelligence (optional — for resume extraction) ───────────
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
AZURE_DOCUMENT_INTELLIGENCE_KEY=

# ─── Azure AI Search (optional — for grounded career coaching) ────────────────
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_API_KEY=
AZURE_SEARCH_INDEX_NAME=
